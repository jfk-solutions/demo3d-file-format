{
  "name": "@jfk-solutions/demo3d-file-format",
  "version": "1.7.0",
  "description": "Browser-first TypeScript parser for Demo3D .demo3d and .raw3d files.",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./three": {
      "types": "./dist/three/index.d.ts",
      "import": "./dist/three/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "demo:three": "npm run build && node scripts/serve-demo.mjs examples/three-render-smoke.html",
    "test": "vitest run",
    "test:browser": "npm run build && playwright test",
    "test:watch": "vitest"
  },
  "keywords": [
    "demo3d",
    "raw3d",
    "emulate3d",
    "parser",
    "typescript",
    "esm"
  ],
  "license": "MIT",
  "peerDependencies": {
    "three": "^0.185.1"
  },
  "peerDependenciesMeta": {
    "three": {
      "optional": true
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.1",
    "@types/three": "^0.185.1",
    "@xmldom/xmldom": "^0.9.10",
    "three": "^0.185.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
